---
services:
  sair-orchestrator:
    image: {{ sair_orchestrator_image }}
    container_name: sair-orchestrator
    restart: unless-stopped
    networks:
      - {{ sair_network_name }}
    extra_hosts:
      - "host.docker.internal:host-gateway"
    environment:
      ORCHESTRATOR_PORT: "{{ sair_orchestrator_port }}"
      SAIR_API_KEY: "{{ sair_api_key }}"
{% if sair_tenant_config %}
      SAIR_TENANT_CONFIG: "{{ sair_tenant_config }}"
{% endif %}
{% if sair_device_source_config %}
      DEVICE_SOURCE_CONFIG: "{{ sair_device_source_config }}"
{% else %}
      DEVICE_SOURCE_ADDR: "host.docker.internal:{{ sair_devicesource_port }}"
{% endif %}

  sair-adb-proxy:
    image: {{ sair_adbproxy_image }}
    container_name: sair-adb-proxy
    restart: unless-stopped
    networks:
      - {{ sair_network_name }}
    depends_on:
      - sair-orchestrator
    environment:
      ORCHESTRATOR_ADDR: "sair-orchestrator:{{ sair_orchestrator_port }}"
      SAIR_API_KEY: "{{ sair_api_key }}"

{% for runner in sair_runners %}
  sair-runner-{{ runner.name }}:
    image: {{ sair_runner_image }}
    container_name: sair-runner-{{ runner.name }}
    restart: unless-stopped
    network_mode: "container:sair-adb-proxy"
    depends_on:
      - sair-adb-proxy
    volumes:
      - runner-data-{{ runner.name }}:/runner-data
    environment:
      ACCESS_TOKEN: "{{ sair_runner_pat }}"
      RUNNER_NAME_PREFIX: "sair-{{ runner.name }}"
      LABELS: "{{ runner.labels }}"
      REPO_URL: "{{ runner.repo_url }}"
      DISABLE_AUTO_UPDATE: "true"

{% endfor %}
networks:
  {{ sair_network_name }}:
    driver: bridge

volumes:
{% for runner in sair_runners %}
  runner-data-{{ runner.name }}:
{% endfor %}
